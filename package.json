{
  "name": "paper-read",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.1",
  "scripts": {
    "dev:desktop": "pnpm --filter @paper-read/desktop tauri:dev",
    "dev:ui": "pnpm --filter @paper-read/desktop dev",
    "build:shared": "pnpm --filter @paper-read/shared build",
    "build:agent-runtime": "pnpm --filter @paper-read/agent-runtime build",
    "build:source-connectors": "pnpm --filter @paper-read/source-connectors build",
    "build:prompt-spec": "pnpm --filter @paper-read/prompt-spec build",
    "build:desktop": "pnpm --filter @paper-read/desktop build",
    "tauri:build": "pnpm --filter @paper-read/desktop tauri:build",
    "build": "pnpm run build:shared && pnpm run build:source-connectors && pnpm run build:prompt-spec && pnpm run build:agent-runtime && pnpm run build:desktop"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  },
  "pnpm": {
    "overrides": {
      "@types/bun": "^1.2.21",
      "@types/node": "^25.5.0",
      "@tailwindcss/vite": "^4.1.13",
      "@tauri-apps/api": "^2.0.0",
      "@tauri-apps/cli": "^2.0.0",
      "tailwindcss": "^4.1.13",
      "typescript": "^6.0.2",
      "zod": "^4.3.6"
    }
  }
}
