{
  "compilerOptions": {
    "target": "ES2022",
    "baseUrl": ".",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@paper-read/shared": [
        "packages/shared/src/index.ts"
      ]
    }
  }
}
